{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Harness: 建立 Baseline",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "if (Test-Path docs/專案基準建立與還原指令.md) { & "$env:USERPROFILE\\.gemini\\antigravity\\execute_baseline.ps1" -Action Backup } else { Write-Host '未找到基準建立指令，已自動進行 Git 暫存備份...'; git stash save 'Harness Baseline Auto-Backup' }"
            ],
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Harness: 執行 BDD 驗證 (behave)",
            "type": "shell",
            "command": "behave",
            "args": [
                "-f",
                "json",
                "-o",
                "04_testing/outputs/test_report.json",
                "-f",
                "html",
                "-o",
                "04_testing/outputs/test_report.html"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Harness: 執行全域連貫性稽核",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Write-Host '啟動全域連貫性稽核中...'; Write-Host '比對 traceability_matrix.md 與 system_specification.md...'; # 後續將調用獨立 python/C# 稽核工具"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Harness: 執行還原 (Restore Baseline)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "if (Test-Path docs/專案基準建立與還原指令.md) { & "$env:USERPROFILE\\.gemini\\antigravity\\execute_baseline.ps1" -Action Restore } else { Write-Host '還原中...'; git stash pop }"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Harness: 驗證組態基準雜湊值",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Write-Host '驗證 build_manifest.json 中組態項之 SHA-256 雜湊值中...'"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
